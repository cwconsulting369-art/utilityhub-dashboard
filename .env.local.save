# ── Browser-sicher (NEXT_PUBLIC_) ─────────────────────────────────────────────
# Abgesichert durch RLS — sicher für Client Components und Server Components.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# ── Ausschließlich serverseitig ────────────────────────────────────────────────
# Nur in lib/supabase/admin.ts verwenden (Route Handlers, Server Actions).
# Bypasses RLS vollständig — NIEMALS an den Browser weitergeben.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
